{
  "captureDate": "2026-04-03",
  "bcVersion": "BC27 (27.0.46760.0)",
  "server": "http://cronus27/BC",
  "wsEndpoint": "ws://cronus27/BC/csh",
  "captureMethod": "Playwright CDP + WebSocket.prototype.send monkey-patch on Web Worker",

  "findings": {
    "webSocketLocation": "BC creates the WebSocket inside a Web Worker (blob: URL), NOT in the main frame or iframe. This is why page-level interception fails.",
    "batchedInteractions": "BC can send MULTIPLE interactions in a single Invoke call via the interactionsToInvoke array. SetCurrentRowAndRowsSelection + ScrollRepeater are often batched together.",
    "factboxRefresh": "Factbox data refresh is triggered SERVER-SIDE as a response to SetCurrentRowAndRowsSelection. No separate 'refresh factbox' call is needed from the client.",
    "scrollDirection": "ScrollRepeater delta=1 for down, delta=-1 for up. The client debounces scroll events and sends a single ScrollRepeater per batch.",
    "systemAction134": "Ctrl+End sends InvokeAction with systemAction=134, which is NOT in the documented SystemAction enum. This appears to be 'GoToLast' or similar."
  },

  "interaction_SetCurrentRowAndRowsSelection": {
    "description": "Sent when a row is selected in a list (click, arrow key, page down). Triggers factbox refresh server-side.",
    "interactionName": "SetCurrentRowAndRowsSelection",
    "controlPath": "server:c[N]  (the repeater control path, e.g. server:c[2] for Sales Orders, server:c[3] for G/L Entries)",
    "formId": "the list page's formId",
    "namedParameters": {
      "key": "bookmark of the row to select (base64 encoded)",
      "selectAll": false,
      "rowsToSelect": ["array with the bookmark of the row to select"],
      "unselectAll": true,
      "rowsToUnselect": []
    },
    "example": {
      "interactionName": "SetCurrentRowAndRowsSelection",
      "skipExtendingSessionLifetime": false,
      "namedParameters": "{\"key\":\"1D_JAAAAACLAQAAAAJ7BjEAMAAxADAAMAA2\",\"selectAll\":false,\"rowsToSelect\":[\"1D_JAAAAACLAQAAAAJ7BjEAMAAxADAAMAA2\"],\"unselectAll\":true,\"rowsToUnselect\":[]}",
      "controlPath": "server:c[2]",
      "formId": "22A1",
      "callbackId": "15"
    }
  },

  "interaction_ScrollRepeater": {
    "description": "Sent when the viewport needs more rows (scrolling past loaded data). Often batched with SetCurrentRowAndRowsSelection.",
    "interactionName": "ScrollRepeater",
    "controlPath": "server:c[N]  (same repeater control path)",
    "formId": "the list page's formId",
    "namedParameters": {
      "delta": "1 for down (next page), -1 for up (previous page)"
    },
    "example": {
      "interactionName": "ScrollRepeater",
      "skipExtendingSessionLifetime": false,
      "namedParameters": "{\"delta\":1}",
      "controlPath": "server:c[3]",
      "formId": "22C4",
      "callbackId": "u"
    }
  },

  "interaction_InvokeAction_GoToLast": {
    "description": "Sent when user presses Ctrl+End to jump to the last row.",
    "interactionName": "InvokeAction",
    "controlPath": "server:c[N]  (repeater control path)",
    "namedParameters": {
      "systemAction": 134,
      "key": null,
      "repeaterControlTarget": null
    },
    "note": "systemAction 134 is not in the standard SystemAction enum. Likely 'GoToLastRow' or 'End'."
  },

